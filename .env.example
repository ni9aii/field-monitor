# field-monitor — environment overrides (example, copy to .env)
#
# Operators MAY keep a local .env (gitignored) to point the agent at a
# private, gitignored config and to supply real secrets. This file is
# only a template — it contains no real values.
#
# NOTE: the server inventory (IPs, SSH key paths, users, ports) stays in
# config.toml (private, gitignored), NOT here. .env is for env-level
# overrides and genuine secrets only.

# Path to your private config.toml (overrides the default ./config.toml).
# FIELD_MONITOR_CONFIG=/abs/path/to/your/private/config.toml

# Real secrets (never commit these). Reserved for future use:
# CORRO_API_URL=...       # reference measurement API (operator-configured)
# CORRO_CC=...             # country code for cross-check
# SSH_KEY_PASSPHRASE=...  # only if your SSH keys are passphrase-protected
