{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 6am"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor", "major"],
      "automerge": false,
      "labels": ["dependencies"]
    }
  ],
  "labels": {
    "dependencies": {
      "additionalReviewers": [],
      "automerge": false
    }
  }
}